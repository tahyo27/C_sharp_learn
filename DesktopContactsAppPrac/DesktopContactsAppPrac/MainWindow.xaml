<Window x:Class="DesktopContactsAppPrac.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopContactsAppPrac"
        xmlns:uc="clr-namespace:DesktopContactsAppPrac.Controls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <Button Content="New contact"
                             Click="Button_Click"
                             />
            <TextBox Margin="0 5 0 5" 
                             TextChanged="TextBox_TextChanged"/>
            <ListView x:Name="contactsListView"
                      SelectionChanged="contactsListView_SelectionChanged"
                      Height="280"
                      Margin="0 5 0 0" >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <uc:ContactControl Contact="{Binding}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
        
    </Grid>
</Window>
